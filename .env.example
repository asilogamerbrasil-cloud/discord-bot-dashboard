# ============================================
# Discord Bot - Credenciais
# ============================================
DISCORD_TOKEN=seu_token_aqui
DISCORD_CLIENT_ID=seu_client_id_aqui
DISCORD_CLIENT_SECRET=seu_client_secret_aqui
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ============================================
# Dashboard
# ============================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=seu_secret_aleatorio_aqui

# ============================================
# Banco de Dados (SQLite)
# ============================================
DATABASE_URL=file:./data/bot.db

# ============================================
# Chave interna para comunicacao bot <-> dashboard
# ============================================
INTERNAL_API_KEY=sua_chave_secreta_interna

# ============================================
# Dashboard URL (para o bot chamar a API)
# ============================================
DASHBOARD_URL=https://dashboard-production-5c50.up.railway.app
